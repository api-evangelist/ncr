{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quantity",
  "description": "Quantity schema from NCR Voyix Commerce Platform APIs",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ncr/refs/heads/main/json-schema/ncr-voyix-commerce-platform-quantity-schema.json",
  "type": "object",
  "properties": {
    "unitOfMeasure": {
      "type": "string",
      "example": "EA"
    },
    "unitOfMeasureLabel": {
      "type": "string",
      "example": "example"
    },
    "value": {
      "type": "number",
      "example": 9.99
    }
  }
}