{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ItemCodeList",
  "description": "ItemCodeList schema from NCR Voyix Commerce Platform APIs",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ncr/refs/heads/main/json-schema/ncr-voyix-commerce-platform-item-code-list-schema.json",
  "type": "object",
  "properties": {
    "itemIds": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "itemCode": {
            "type": "string"
          }
        },
        "required": [
          "itemCode"
        ]
      }
    }
  },
  "required": [
    "itemIds"
  ]
}