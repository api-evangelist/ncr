{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TokenResponse",
  "description": "TokenResponse schema from NCR Voyix Commerce Platform APIs",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ncr/refs/heads/main/json-schema/ncr-voyix-commerce-platform-token-response-schema.json",
  "type": "object",
  "properties": {
    "token": {
      "type": "string",
      "example": "eyJhbGciOiJIUzI1Ni1.abc123.def456"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "example": "2026-06-02T14:30:00Z"
    }
  }
}