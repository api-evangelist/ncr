{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserInput",
  "description": "UserInput schema from NCR Voyix Commerce Platform APIs",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ncr/refs/heads/main/json-schema/ncr-voyix-commerce-platform-user-input-schema.json",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "example": "jsmith"
    },
    "email": {
      "type": "string",
      "format": "email",
      "example": "jsmith@example.com"
    },
    "firstName": {
      "type": "string",
      "example": "Downtown Store"
    },
    "lastName": {
      "type": "string",
      "example": "Downtown Store"
    }
  },
  "required": [
    "username"
  ]
}