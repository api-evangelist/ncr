{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "description": "UserProfile schema from NCR Voyix Commerce Platform APIs",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ncr/refs/heads/main/json-structure/ncr-voyix-commerce-platform-user-profile-structure.json",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "example": "jsmith"
    },
    "email": {
      "type": "string",
      "example": "jsmith@example.com"
    },
    "firstName": {
      "type": "string",
      "example": "Downtown Store"
    },
    "lastName": {
      "type": "string",
      "example": "Downtown Store"
    },
    "organization": {
      "type": "string",
      "example": "example"
    }
  },
  "name": "UserProfile"
}